{
  "name": "@u7-scl/onboarding",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "bun test",
    "lint": "bunx biome check .",
    "tslint": "tsc --noEmit",
    "format": "bunx biome check . --write",
    "check": "bun run lint && bun run tslint && bun test"
  },
  "dependencies": {
    "@u7-scl/app": "workspace:*",
    "@u7-scl/core": "workspace:*",
    "@u7-scl/user": "workspace:*"
  },
  "exports": {
    ".": "./src/index.ts",
    "./domain": "./src/domain/index.ts",
    "./api": "./src/api/index.ts",
    "./infra": "./src/infra/index.ts"
  },
  "imports": {
    "#domain/*": "./src/domain/*.ts",
    "#api/*": "./src/api/*.ts",
    "#infra/*": "./src/infra/*.ts"
  }
}
