{
  "title": "Stream",
  "type": "object",
  "properties": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "mentorId": {
      "type": "string",
      "format": "uuid"
    },
    "moduleId": {
      "type": "string",
      "format": "uuid"
    },
    "startDate": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": ["enrollment", "active", "completed", "archived"],
      "type": "string"
    },
    "telegramGroupId": {
      "type": "string"
    },
    "telegramGroupInvite": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "result": {
      "type": "string"
    },
    "rules": {
      "type": "string"
    },
    "additional": {
      "type": "string"
    },
    "targetAudience": {
      "type": "string"
    },
    "contentSnapshot": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "projectId": {
            "type": "string",
            "format": "uuid"
          },
          "projectTitle": {
            "type": "string",
            "minLength": 1
          },
          "lessons": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "lessonId": {
                  "type": "string",
                  "format": "uuid"
                },
                "lessonTitle": {
                  "type": "string",
                  "minLength": 1
                },
                "stepIds": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "format": "uuid"
                  }
                }
              },
              "required": ["lessonId", "lessonTitle", "stepIds"]
            }
          }
        },
        "required": ["projectId", "projectTitle", "lessons"]
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "uuid",
    "title",
    "description",
    "mentorId",
    "moduleId",
    "startDate",
    "status",
    "contentSnapshot",
    "createdAt"
  ]
}
