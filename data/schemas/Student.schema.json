{
  "title": "Student",
  "type": "object",
  "properties": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "streamId": {
      "type": "string",
      "format": "uuid"
    },
    "userId": {
      "type": "string",
      "format": "uuid"
    },
    "enrolledAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": ["active", "completed", "dropped"],
      "type": "string"
    },
    "currentStepId": {
      "type": "string",
      "format": "uuid"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "stepId": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "enum": ["issued", "completed"],
            "type": "string"
          },
          "issuedAt": {
            "type": "string",
            "format": "date-time"
          },
          "completedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": ["stepId", "status", "issuedAt"]
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "uuid",
    "streamId",
    "userId",
    "enrolledAt",
    "status",
    "currentStepId",
    "steps",
    "createdAt"
  ]
}
