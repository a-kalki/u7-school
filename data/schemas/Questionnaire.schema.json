{
  "title": "Questionnaire",
  "type": "object",
  "properties": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "telegramId": {
      "type": "number",
      "minimum": 1
    },
    "status": {
      "enum": ["in_progress", "completed", "abandoned"],
      "type": "string"
    },
    "answers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "questionCode": {
            "type": "string",
            "minLength": 1
          },
          "answerCodes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "textValue": {
            "type": "string",
            "minLength": 1
          },
          "answeredAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": ["questionCode", "answerCodes", "answeredAt"]
      }
    },
    "currentQuestionCode": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "draftAnswers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "uuid",
    "telegramId",
    "status",
    "answers",
    "currentQuestionCode",
    "createdAt"
  ]
}
