{
  "title": "Lesson",
  "type": "object",
  "properties": {
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "moduleId": {
      "type": "string",
      "format": "uuid"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "additional": {
      "type": "string"
    },
    "status": {
      "enum": [
        "draft",
        "published",
        "archived"
      ],
      "type": "string"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "estimatedMinutes": {
      "type": "integer",
      "minimum": 1
    },
    "stepIds": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "mentorStepIds": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    }
  },
  "required": [
    "uuid",
    "moduleId",
    "title",
    "status",
    "createdAt",
    "stepIds",
    "mentorStepIds"
  ]
}