{
  "name": "u7-school",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "test:p": "bash -c 'bun run --cwd \"packages/${0}\" test'",
    "test:a": "bash -c 'bun run --cwd \"apps/${0}\" test'",
    "lint": "bunx biome check .",
    "lint:p": "bash -c 'bun run --cwd \"packages/${0}\" lint'",
    "lint:a": "bash -c 'bun run --cwd \"apps/${0}\" lint'",
    "format": "bunx biome check . --write",
    "tslint": "tsc --noEmit",
    "tslint:p": "bash -c 'bun run --cwd \"packages/${0}\" tslint'",
    "tslint:a": "bash -c 'bun run --cwd \"apps/${0}\" tslint'",
    "check": "bun run lint && bun run tslint && bun test",
    "check:p": "bash -c 'bun run --cwd \"packages/${0}\" check'",
    "check:a": "bash -c 'bun run --cwd \"apps/${0}\" check'"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "valibot": "^1.0.0",
    "@google/genai": "^1.51.0",
    "openai": "^6.35.0"
  }
}
