{
  "name": "u7-school",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "test:bot": "bun test packages/stream/src/ui/bot/ tests/bot/",
    "seed:fixtures": "bun run apps/u7-bot/scripts/seed-fixtures.ts",
    "dev:fixtures": "bun run seed:fixtures && DB_DIR=./data-fixtures bun run apps/u7-bot/src/main.ts",
    "test:p": "bash -c 'bun run --cwd \"packages/${0}\" test'",
    "test:a": "bash -c 'bun run --cwd \"apps/${0}\" test'",
    "lint": "bunx biome check .",
    "lint:p": "bash -c 'bun run --cwd \"packages/${0}\" lint'",
    "lint:a": "bash -c 'bun run --cwd \"apps/${0}\" lint'",
    "format": "bunx biome check . --write",
    "tslint": "tsc --noEmit",
    "tslint:p": "bash -c 'bun run --cwd \"packages/${0}\" tslint'",
    "tslint:a": "bash -c 'bun run --cwd \"apps/${0}\" tslint'",
    "check": "bun run lint && bun run tslint && bun test",
    "check:p": "bash -c 'bun run --cwd \"packages/${0}\" check'",
    "check:a": "bash -c 'bun run --cwd \"apps/${0}\" check'",
    "start:prod": "pm2 start pm2.config.cjs --env production",
    "start:prod:stop": "pm2 stop pm2.config.cjs",
    "start:prod:restart": "pm2 restart pm2.config.cjs --update-env"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "@types/markdown-it": "^14.1.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@valibot/to-json-schema": "^1.7.1",
    "markdown-to-telegram": "^0.0.7",
    "openai": "^6.35.0",
    "valibot": "^1.0.0"
  }
}
