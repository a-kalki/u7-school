{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "types": ["bun", "node"],
    "baseUrl": ".",
    "paths": {
      "@u7-scl/user/domain": ["packages/user/src/domain/index.ts"],
      "@u7-scl/user/api": ["packages/user/src/api/index.ts"],
      "@u7-scl/user/ui": ["packages/user/src/ui/index.ts"],
      "@u7-scl/user/infra": ["packages/user/src/infra/index.ts"],
      "@u7-scl/core/domain": ["packages/core/src/domain/index.ts"],
      "@u7-scl/core/api": ["packages/core/src/api/index.ts"],
      "@u7-scl/core/ui": ["packages/core/src/ui/index.ts"],
      "@u7-scl/core/shared": ["packages/core/src/shared/index.ts"],
      "@u7-scl/course": ["packages/course/src/index.ts"],
      "@u7-scl/stream": ["packages/stream/src/index.ts"],
      "@u7-scl/onboarding": ["packages/onboarding/src/index.ts"],
      "@u7-scl/w3school": ["packages/w3school/src/index.ts"],
      "@u7-scl/app": ["packages/app/src/index.ts"],
      "@u7-scl/app/domain": ["packages/app/src/domain/index.ts"],
      "@u7-scl/app/ui": ["packages/app/src/ui/index.ts"],
      "@u7-scl/app/shared": ["packages/app/src/shared/index.ts"],
      "@u7-scl/app/api": ["packages/app/src/api/index.ts"]
    }
  }
}
