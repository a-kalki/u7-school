{
	"compilerOptions": {
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false,
		"baseUrl": ".",
		"paths": {
			"@u7/user": ["packages/user/src/index.ts"],
			"@u7/user/domain": ["packages/user/src/domain/index.ts"],
			"@u7/user/api": ["packages/user/src/api/index.ts"],
			"@u7/user/ui": ["packages/user/src/ui/index.ts"],
			"@u7/user/infra": ["packages/user/src/infra/index.ts"],
			"@u7/core": ["packages/core/src/index.ts"],
			"@u7/core/domain": ["packages/core/src/domain/index.ts"],
			"@u7/core/api": ["packages/core/src/api/index.ts"],
			"@u7/core/ui": ["packages/core/src/ui/index.ts"],
			"@u7/core/shared": ["packages/core/src/shared/index.ts"],
			"@u7/course": ["packages/course/src/index.ts"],
			"@u7/w3school": ["packages/w3school/src/index.ts"]
		}
	}
}
